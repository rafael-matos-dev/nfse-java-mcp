# Copie para .env e preencha. NUNCA commite o .env nem o certificado.
# O .gitignore ja bloqueia .env, *.pfx e *.p12.

# Certificado digital A1 do prestador
NFSE_CERT_PATH=/caminho/para/seu-certificado.pfx
NFSE_CERT_PASSWORD=troque-esta-senha

# Opcional: diretorio onde o XML assinado das emissoes bem-sucedidas e salvo.
# Padrao: ./nfse-success-xml/ . Esses XMLs contem dados reais; nao commite.
# NFSE_XML_SUCCESS_LOG_DIR=/caminho/local
